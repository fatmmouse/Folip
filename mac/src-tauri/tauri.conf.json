{
  "productName": "Folip",
  "version": "0.1.0",
  "identifier": "com.folip.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": false,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Folip",
        "width": 360,
        "height": 480,
        "decorations": false,
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false
      }
    ]
  }
}
